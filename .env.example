# ============================================================================
# RACCOON SIGNAL / V16 — COMPLETE VERCEL ENVIRONMENT TEMPLATE
# Never commit real secrets. Add these in Vercel Project Settings → Environment Variables.
# ============================================================================

# Core URL and runtime
APP_BASE_URL=https://your-domain.fi
NEXT_TELEMETRY_DISABLED=1

# Authentication and owner account
AUTH_SECRET=replace_with_at_least_32_random_characters
SESSION_DAYS=14
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_long_unique_password
# Optional owner MFA. Base32 TOTP secret used by an authenticator app.
ADMIN_TOTP_SECRET=

# Optional second private chat-only account
FRIEND_USERNAME=chat
FRIEND_PASSWORD=replace_with_a_different_password
# Older aliases supported by the code
USER_USERNAME=
USER_PASSWORD=

# Neon Postgres — use Neon's pooled connection string
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/database?sslmode=require

# Independent encryption / analytics secrets
# Do not reuse AUTH_SECRET. Do not change CREDENTIAL_ENCRYPTION_KEY after users save keys.
CREDENTIAL_ENCRYPTION_KEY=replace_with_an_independent_random_secret_at_least_32_characters
ANALYTICS_SALT=replace_with_a_random_secret_used_only_for_pseudonymous_analytics

# Public brand and legal identity
NEXT_PUBLIC_SERVICE_NAME=Raccoon Signal
NEXT_PUBLIC_SERVICE_EMAIL=hello@your-domain.fi
NEXT_PUBLIC_SERVICE_PHONE=
NEXT_PUBLIC_SERVICE_LOCATION=Finland
LEGAL_BUSINESS_NAME=
LEGAL_BUSINESS_ID=
LEGAL_VAT_ID=
LEGAL_STREET_ADDRESS=
LEGAL_POSTAL_ADDRESS=
LEGAL_COUNTRY=Finland
LEGAL_DISPUTE_COURT=
PRIVACY_CONTACT_EMAIL=privacy@your-domain.fi
NEXT_PUBLIC_VAT_REGISTERED=false
NEXT_PUBLIC_VAT_RATE=25.5

# Public contact forms / Resend
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=Raccoon Signal <hello@your-verified-domain.fi>
RESEND_FROM=Raccoon Signal <hello@your-verified-domain.fi>
PUBLIC_CONTACT_TO_EMAIL=you@your-domain.fi
PUBLIC_CONTACT_FROM_EMAIL=Raccoon Signal <website@your-verified-domain.fi>
CONTACT_TO_EMAIL=you@your-domain.fi
CONTACT_FROM_EMAIL=Raccoon Signal <website@your-verified-domain.fi>

# Alternative SMTP / Gmail app password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Gmail inbox / read / reply through Google OAuth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=https://your-domain.fi/api/email/google/callback

# Google business tools
# The owner dashboard accepts these server keys. SaaS customers can save their own keys.
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
GOOGLE_GEOCODING_API_KEY=
PAGESPEED_API_KEY=

# Optional Browserless fallback for JavaScript-rendered contact pages/screenshots
BROWSERLESS_TOKEN=
BROWSERLESS_BASE_URL=https://production-sfo.browserless.io

# Optional Claude enhancement — core features continue without it
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5

# YouTube personal page
YOUTUBE_API_KEY=

# Twitch personal page
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Reddit personal page — no API credentials required.
# Optional descriptive user agent for the public RSS reader.
REDDIT_RSS_USER_AGENT=Mozilla/5.0 (compatible; RaccoonSignal/16; +https://your-domain.fi)

# Stripe SaaS subscriptions
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_BUSINESS=
STRIPE_PRICE_AGENCY=

# Twilio SMS and phone verification
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_MESSAGING_SERVICE_SID=

# Private Vercel Blob for chat attachments
# Vercel projects connected to Blob normally receive credentials automatically.
BLOB_READ_WRITE_TOKEN=
CHAT_MAX_UPLOAD_MB=4
CHAT_TTL_HOURS=0
# Emergency legacy fallback; normally keep false.
CHAT_ALLOW_DATABASE_ATTACHMENTS=false

# Public-form spam protection
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Generated customer-site inquiry webhook
INQUIRY_WEBHOOK_SECRET=replace_with_a_long_random_shared_secret
# These three are normally placed on each generated customer website, not this dashboard:
DASHBOARD_INQUIRY_WEBHOOK=https://your-domain.fi/api/business/inquiries/public
DASHBOARD_INQUIRY_SECRET=the_same_value_as_INQUIRY_WEBHOOK_SECRET
DASHBOARD_LEAD_ID=

# Development workspace — production remains disabled by default
DEV_WORKSPACE_ROOT=
DEV_ALLOW_ARBITRARY_COMMANDS=false
# Do not enable this on a public deployment.
ENABLE_PRODUCTION_DEV_WORKSPACE=
