# Authentication
AUTH_SECRET=replace_with_at_least_32_random_characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_long_unique_password
FRIEND_USERNAME=chat
FRIEND_PASSWORD=replace_with_a_different_password
SESSION_DAYS=14

# Neon (use the pooled DATABASE_URL supplied by Neon/Vercel)
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/database?sslmode=require

# Google Places (New) + Geocoding API
GOOGLE_MAPS_API_KEY=

# Private Vercel Blob store for chat images/videos.
# On Vercel, connect a private Blob store to the project; OIDC is used automatically.
# For local development outside Vercel, a token can be supplied:
BLOB_READ_WRITE_TOKEN=
CHAT_MAX_UPLOAD_MB=4
CHAT_TTL_HOURS=0

# Optional YouTube
YOUTUBE_API_KEY=

# Optional Reddit read-only module
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=private-terminal-dashboard/1.0

# Dashboard email sender (Resend recommended)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=Jonas <you@yourdomain.com>

# Alternative Gmail SMTP
GMAIL_USER=
GMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# Dev Workspace is automatically disabled on Vercel/production.
# Deliberate override (not recommended):
# ENABLE_PRODUCTION_DEV_WORKSPACE=I_UNDERSTAND_THE_RISK
# DEV_ALLOW_ARBITRARY_COMMANDS=true
# DEV_WORKSPACE_ROOT=C:\path\to\project
