# Authentication
AUTH_SECRET=replace_with_at_least_32_random_characters
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace_with_a_long_unique_password
FRIEND_USERNAME=chat
FRIEND_PASSWORD=replace_with_a_different_password
SESSION_DAYS=14

# Neon (use the pooled DATABASE_URL supplied by Neon/Vercel)
DATABASE_URL=postgresql://user:password@host-pooler.region.aws.neon.tech/database?sslmode=require

# Google Places (New) + Geocoding API
GOOGLE_MAPS_API_KEY=

# Private Vercel Blob store for chat images/videos.
# On Vercel, connect a private Blob store to the project; OIDC is used automatically.
# For local development outside Vercel, a token can be supplied:
BLOB_READ_WRITE_TOKEN=
CHAT_MAX_UPLOAD_MB=4
CHAT_TTL_HOURS=0

# Optional YouTube
YOUTUBE_API_KEY=

# Optional Twitch Artifact live-category listing.
# Create a Twitch developer application; saved channel embeds work even without these.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Dashboard email sender (Resend recommended)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM=Raccoon North <you@yourdomain.com>

# Alternative Gmail SMTP
GMAIL_USER=
GMAIL_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true

# Dev Workspace is automatically disabled on Vercel/production.
# Deliberate override (not recommended):
# ENABLE_PRODUCTION_DEV_WORKSPACE=I_UNDERSTAND_THE_RISK
# DEV_ALLOW_ARBITRARY_COMMANDS=true
# DEV_WORKSPACE_ROOT=C:\path\to\project

# Public dashboard address used by Gmail OAuth and Twilio webhook validation
APP_BASE_URL=https://your-dashboard.vercel.app

# Gmail inbox/read/reply integration (Google Cloud OAuth web client)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Usually: https://your-dashboard.vercel.app/api/email/google/callback
GOOGLE_OAUTH_REDIRECT_URI=

# Two-way SMS through Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Optional Messaging Service instead of TWILIO_FROM_NUMBER
TWILIO_MESSAGING_SERVICE_SID=

# Optional rendered-browser fallback for JavaScript-only contact details/screenshots
BROWSERLESS_TOKEN=
BROWSERLESS_BASE_URL=https://production-sfo.browserless.io

# Optional higher PageSpeed API quota
PAGESPEED_API_KEY=

# Shared by this dashboard and generated client websites.
# Generate a long random value; generated websites send inquiries to the CRM with it.
INQUIRY_WEBHOOK_SECRET=

# Public website-service landing page
NEXT_PUBLIC_SERVICE_EMAIL=
NEXT_PUBLIC_SERVICE_LOCATION=Finland
# Where landing-page inquiry notifications are sent. Inquiries are always saved in Neon.
PUBLIC_CONTACT_TO_EMAIL=
PUBLIC_CONTACT_FROM_EMAIL=Raccoon North <website@your-verified-domain.com>

# Optional Cloudflare Turnstile spam protection for public forms
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Public brand and legal identity
# Working brand only: check availability in PRH/YTJ and trademark databases before commercial use.
NEXT_PUBLIC_SERVICE_NAME=Raccoon North
LEGAL_BUSINESS_NAME=
LEGAL_BUSINESS_ID=
LEGAL_VAT_ID=
LEGAL_STREET_ADDRESS=
LEGAL_POSTAL_ADDRESS=
LEGAL_COUNTRY=Finland
LEGAL_DISPUTE_COURT=
NEXT_PUBLIC_SERVICE_PHONE=
PRIVACY_CONTACT_EMAIL=
# Standard Finnish VAT is currently 25.5%. Set registered=false until the actual entity is VAT-registered.
NEXT_PUBLIC_VAT_REGISTERED=false
NEXT_PUBLIC_VAT_RATE=25.5

# Optional Claude enhancement. The site remains functional without it.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
