# Neon database. Your Vercel project can already have this.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/DB?sslmode=require"

# YouTube text browser
YOUTUBE_API_KEY=""

# Local PC model through Vercel
# LOCAL_LLM_URL must be a public HTTPS tunnel URL that points to local/llm-bridge.mjs on your PC.
LOCAL_LLM_URL="https://your-pc-tunnel.example.com"
LOCAL_LLM_TOKEN="change-this-long-random-secret"
LOCAL_LLM_MODEL="llama3.1"
LOCAL_LLM_TIMEOUT_MS="55000"
# Optional: if set, /llm asks for this key before Vercel will relay to your PC.
DASHBOARD_ACCESS_KEY=""

# Local LLM bridge on your PC
LOCAL_LLM_BRIDGE_PORT="43111"
LOCAL_LLM_BRIDGE_HOST="127.0.0.1"
OLLAMA_URL="http://127.0.0.1:11434"
OLLAMA_NUM_PREDICT="2048"

# Local movie server only
MOVIE_PORT="43110"
MOVIE_DIR="C:\\Users\\Jonas\\Videos"
LOCAL_ALLOWED_ORIGIN="*"
